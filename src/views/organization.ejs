<%- include('partials/header') %>
<main>
    <h1><%= title %></h1>

    <% if (organizationDetails) { %>
        <h2><%= organizationDetails.name %></h2>
        <img src="/images/<%= organizationDetails.logo_filename %>" 
             alt="<%= organizationDetails.name %> logo" 
             style="max-width:200px; height:auto;">
        <p><%= organizationDetails.description %></p>
        <p><strong>Contact:</strong> <%= organizationDetails.contact_email %></p>

        <h3>Service Projects</h3>
        <% if (projects.length > 0) { %>
            <ul>
                <% projects.forEach(project => { %>
                    <li>
                        <a href="/project/<%= project.project_id %>">
                            <%= project.title %>
                        </a> - <%= project.project_date %> (<%= project.location %>)
                    </li>
                <% }); %>
            </ul>
        <% } else { %>
            <p>No projects found for this organization.</p>
        <% } %>
    <% } else { %>
        <p>Organization not found.</p>
    <% } %>
</main>
<%- include('partials/footer') %>
